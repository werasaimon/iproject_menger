#!/usr/bin/env python3
"""
Route inbox messages to the right AI CLI based on @prefix.
All AI workers run as background processes — dispatch returns immediately.

  @codex <task>   → codex CLI (fast, mechanical edits)
  @gemini <q>     → gemini CLI (research, explanations)
  @openai <task>  → codex CLI with GPT-5/OpenAI label
  (default)       → write to data/claude_inbox.txt for legacy Claude watcher
"""
import sys, os, json, time, pathlib, subprocess, re

D = pathlib.Path("/home/wera_n/GIT/iproject_menger/data")
REPLY = D / "replies.jsonl"
STATUS = D / "status.json"
CLAUDE_INBOX = D / "claude_inbox.txt"
LOG = D / "dispatch.log"

AGENTS = {
    "claude": {"label": "🤖 Claude", "prefix": "@claude", "engine": "claude"},
    "codex":  {"label": "⚡ Codex", "prefix": "@codex", "engine": "codex"},
    "gemini": {"label": "✦ Gemini", "prefix": "@gemini", "engine": "gemini"},
    "openai": {"label": "◆ GPT-5", "prefix": "@openai", "engine": "codex"},
}
AGENT_RE = re.compile(r"^@(" + "|".join(re.escape(a) for a in AGENTS) + r")\s+(.*)", re.DOTALL)

def _log(msg):
    try:
        LOG.open("a").write(f"{time.strftime('%H:%M:%S')} {msg}\n")
    except Exception:
        pass

def set_status(busy, text=""):
    try:
        STATUS.write_text(json.dumps({"busy": bool(busy), "text": text, "at": time.time()}))
    except Exception:
        pass

def write_reply(text, model):
    entry = {"ts": time.strftime("%H:%M:%S"), "role": "claude",
             "text": f"[{model}] {text}", "model": model}
    try:
        REPLY.open("a").write(json.dumps(entry, ensure_ascii=False) + "\n")
    except Exception as e:
        _log(f"write_reply error: {e}")

def run_cli_agent(agent, task):
    """Fork a CLI-backed agent and return immediately. Writes reply when done."""
    model = agent
    engine = AGENTS[agent]["engine"]
    _log(f"{model} fork: {task[:60]}")
    def _work():
        set_status(True, f"{AGENTS[agent]['label']}: {task[:60]}…")
        try:
            if engine == "codex":
                cmd = ["codex", "exec", task]
                timeout = 180
            elif engine == "claude":
                cmd = ["claude", "-p", "--dangerously-skip-permissions", task]
                timeout = 180
            elif engine == "gemini":
                cmd = ["gemini", "-p", task]
                timeout = 90
            else:
                raise RuntimeError(f"{agent} is not CLI-backed")
            r = subprocess.run(
                cmd,
                capture_output=True, text=True, timeout=timeout,
                cwd="/home/wera_n/GIT/istereolab-sdk"
            )
            out = (r.stdout or "").strip() or (r.stderr or "").strip() or "(нет вывода)"
            write_reply(out[:3000], model)
        except subprocess.TimeoutExpired:
            write_reply(f"(timeout)", model)
        except Exception as e:
            write_reply(f"(ошибка: {e})", model)
        set_status(False)
    import threading
    threading.Thread(target=_work, daemon=True).start()

def route_to_claude(text):
    """Write message to claude_inbox.txt for Claude's watcher."""
    _log(f"claude inbox: {text[:60]}")
    try:
        CLAUDE_INBOX.write_text(text)
    except Exception as e:
        _log(f"claude_inbox error: {e}")
    # Also print for compatibility with the original Claude-reads-stdout flow
    print("FROM_SITE:")
    print(text)

if __name__ == "__main__":
    text = " ".join(sys.argv[1:]).strip() if len(sys.argv) > 1 else sys.stdin.read().strip()
    if not text:
        sys.exit(0)

    m = AGENT_RE.match(text)
    if m:
        ai, task = m.group(1), m.group(2).strip()
        run_cli_agent(ai, task)
        # wait for thread to finish (dispatch itself was already forked by watch)
        import threading, time as _t
        deadline = _t.time() + 200
        while threading.active_count() > 1 and _t.time() < deadline:
            _t.sleep(0.5)
    else:
        route_to_claude(text)
