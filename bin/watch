#!/usr/bin/env bash
# Persistent daemon loop — routes each message through LangGraph.
# Fork & so the loop re-arms before any AI finishes.
N=/home/wera_n/GIT/iproject_menger/data/inbox_new
if [ -f /home/wera_n/GIT/iproject_menger/data/server_dispatch_enabled ]; then
    echo "server-owned dispatch is enabled; bin/watch is legacy and will not run"
    exit 0
fi
while true; do
    rm -f "$N"
    until [ -s "$N" ]; do sleep 2; done
    MSG=$(cat "$N"); rm -f "$N"
    python3 /home/wera_n/GIT/iproject_menger/bin/langgraph_dispatch.py "$MSG" &
done
